{
  "workload_name": "web-app-prod",
  "workload_type": "web_app",
  "environment": "prod",
  "cloud_provider": "aws",
  "region": "us-east-2",
  "traffic_profile": "high",
  "architecture": {
    "compute": "ec2",
    "database": "rds",
    "storage": "s3"
  },
  "availability": {
    "multi_az": false,
    "auto_scaling": false
  },
  "security": {
    "waf_enabled": false,
    "encryption_at_rest": true,
    "encryption_in_transit": true
  },
  "cost": {
    "reserved_instances": false,
    "right_sizing": false
  }
}
